{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Problem",
  "description": "A programming problem",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "difficulty": {
      "type": "string",
      "enum": ["Easy", "Medium", "Hard"]
    },
    "functionName": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
    },
    "parameters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
          },
          "type": { "type": "string", "minLength": 1 }
        },
        "required": ["name", "type"],
        "additionalProperties": false
      }
    },
    "returnType": {
      "type": "string",
      "minLength": 1
    },
    "timeLimitMs": {
      "type": "integer",
      "minimum": 100
    },
    "memoryLimitMb": {
      "type": "integer",
      "minimum": 32
    },
    "compareConfig": {
      "type": "object",
      "properties": {
        "mode": { "type": "string", "enum": ["EXACT", "STRUCTURAL"] },
        "floatTolerance": { "type": "number", "minimum": 0 },
        "orderInsensitive": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "testCases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "inputs": {
            "type": "array",
            "items": {}
          },
          "expected": {},
          "isSample": {
            "type": "boolean"
          },
          "isHidden": {
            "type": "boolean"
          }
        },
        "required": ["inputs", "expected"],
        "additionalProperties": false
      }
    },
    "testsJSON": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "isPremium": {
      "type": "boolean"
    },
    "referenceSolution": {
      "type": "string"
    },
    "solutionLanguage": {
      "type": "string",
      "enum": ["javascript", "python", "java", "go", "cpp", "c", "csharp"]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["title", "description", "difficulty", "functionName", "parameters", "returnType", "testCases"]
}
